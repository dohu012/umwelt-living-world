STEPFUN_API_KEY=
# Optional overrides — defaults match StepFun's OpenAI-compatible API.
# Subscription-plan accounts (订阅用户) go through a different base path — use
# https://api.stepfun.com/step_plan, not the bare https://api.stepfun.com pay-as-you-go one,
# or every call fails with a misleading "quota_exceeded" instead of actually reaching the plan.
# STEPFUN_BASE_URL=https://api.stepfun.com/step_plan
# STEPFUN_MODEL=step-3.7-flash
# STEPFUN_REASONING_EFFORT=low
# Utility calls (state extraction, scene-location resolve) are structured-JSON, not creative
# writing — a non-reasoning model answers just as well and skips step-3.7-flash's hidden
# chain-of-thought tokens, which cut their latency from ~25s to ~10s in testing.
# STEPFUN_UTILITY_MODEL=step-3.5-flash
