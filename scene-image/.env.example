# StepFun Open Platform — https://platform.stepfun.com/
# Prefer configuring these in umwelt 模型服务 UI (对话 / 生图 / 改图三个模型名).
# Values below are fallbacks when the UI provider has no imageModel fields set.
STEP_API_KEY=your_step_api_key_here

# Chinese docs often use api.stepfun.com; some English docs use api.stepfun.ai.
# Subscription-plan accounts (订阅用户) use a different base path — /step_plan/v1, not the bare
# pay-as-you-go /v1 — otherwise calls fail with a misleading "quota_exceeded" error.
STEP_BASE_URL=https://api.stepfun.com/step_plan/v1

# Gen vs edit are different StepFun model ids (same key, two models) on pay-as-you-go accounts:
# - step-2x-large / step-1x-medium: classic text-to-image
# - step-image-edit-2: /v1/images/edits
# This subscription plan's /v1/models only lists step-image-edit-2 — no step-2x-large/step-1x-*
# access — but that same model also does plain text-to-image via /images/generations (no source
# image needed), so both vars point at it here. Only fixed sizes work: 1024x1024, 768x1360,
# 896x1184, 1360x768, 1184x896 (see scene-image/src/prompt_builders.py's DEFAULT_*_SIZE).
STEP_IMAGE_MODEL=step-image-edit-2
STEP_IMAGE_EDIT_MODEL=step-image-edit-2

# Where generated images are saved
SCENE_IMAGE_OUTPUT_DIR=output
